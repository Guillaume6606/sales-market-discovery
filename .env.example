# -------- Core --------
APP_ENV=local
SECRET_KEY=please-change-me

# -------- Logging --------
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# -------- DB --------
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app
POSTGRES_HOST=db
POSTGRES_PORT=5432

# -------- Redis --------
REDIS_URL=redis://redis:6379/0

# -------- APIs --------
API_URL=http://backend:8000
EBAY_APP_ID=your-ebay-app-id
EBAY_CERT_ID=your-ebay-cert-id
# eBay keyset compliance (marketplace account deletion notifications)
# Token: 32-80 chars you invent (openssl rand -hex 32); URL: exact value registered at eBay
EBAY_VERIFICATION_TOKEN=
EBAY_DELETION_ENDPOINT_URL=
KEEPA_API_KEY=your-keepa-key
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# -------- LLM (Gemini) --------
# Auth option 1 (simple): set GEMINI_API_KEY from https://aistudio.google.com — no GCP project needed
# Auth option 2 (Vertex AI): leave GEMINI_API_KEY empty and set GCP_PROJECT_ID + run:
#   gcloud auth application-default login
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
LLM_ENABLED=false
GCP_PROJECT_ID=
GCP_LOCATION=europe-west1

# -------- Telegram --------
TELEGRAM_WEBHOOK_SECRET=     # Random string: openssl rand -hex 32

# -------- Scraping Configuration --------
USE_PLAYWRIGHT=false
# Rotating residential proxy (recommended: IPRoyal, geo-targeted FR)
# Format: http://user:pass@host:port — used by curl_cffi, Playwright, and the LBC client
SCRAPING_PROXY_URL=

# -------- Deployment / Production --------
DOMAIN=market.yourdomain.com
BASIC_AUTH_USER=admin
BASIC_AUTH_HASH=              # Generate with: make caddy-hash PASSWORD=yourpassword 